---
import "../styles/docs-sidebar.css";
import type { DocsSidebarProps, SidebarSection, SidebarConfig } from "../lib/types";

const { headings = [] } = Astro.props as DocsSidebarProps;
const current = Astro.url.pathname;
let sidebarConfig: SidebarConfig;

if (current === '/') {
  // Static homepage sections
  const sections: SidebarSection[] = [
    { name: 'Welcome', href: '#welcome' },
    { name: 'Featured Projects', href: '#featured-projects' },
    { name: 'About', href: '#about' },
    { name: 'Contact', href: '#contact' },
  ];
  sidebarConfig = { sections, label: 'Home Sections' };
} else if (current.startsWith('/docs/')) {
  // For docs pages, use headings from markdown
  const sections: SidebarSection[] = headings.map(heading => ({
    name: heading.text,
    href: `#${heading.id}`,
  }));
  sidebarConfig = { sections, label: 'On This Page' };
} else {
  sidebarConfig = { sections: [], label: 'Sections' };
}
---
<nav class="docs-sidebar" aria-label="Section navigation">
  <div class="sidebar-label">{sidebarConfig.label}</div>
  <ul class="sidebar-list">
    {sidebarConfig.sections.map((section: SidebarSection) => (
      <li>
        <a
          href={section.href}
          class={current === section.href ? 'active' : ''}
          data-section={section.href?.replace('#', '')}
        >
          {section.name}
        </a>
      </li>
    ))}
  </ul>

  <script type="module">
    // Scrollspy logic
    const links = Array.from(document.querySelectorAll('.docs-sidebar a[data-section]'));
    const sectionIds = links.map(link => (link.getAttribute('href') || '').replace('#', ''));
    const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);
    function onScroll() {
      let activeIndex = 0;
      for (let i = 0; i < sections.length; i++) {
        const rect = sections[i].getBoundingClientRect();
        if (rect.top <= 120) {
          activeIndex = i;
        }
      }
      links.forEach((link, i) => {
        if (i === activeIndex) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  </script>
</nav>
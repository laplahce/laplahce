---
import "../styles/navbar.css";
const packages = [
  { name: 'CTFX', href: '/docs/ctfx' },
  { name: 'Water Shader', href: '/docs/water-shader' },
];
---
<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav-logo">
    <img src="/ctfx.jpg" alt="Logo" class="nav-logo-img" />
    <span>Laplahce</span>
  </a>
  <a href="/">Home</a>
  <div class="nav-dropdown">
    <button class="nav-dropdown-btn" tabindex="0">Products <span class="nav-caret">▼</span></button>
    <div class="nav-dropdown-content">
      {packages.map(pkg => (
        <a href={pkg.href}>{pkg.name}</a>
      ))}
    </div>
  </div>
  <a href="#portfolio">Portfolio</a>
  <a href="#support">Support</a>
</nav>
---
import "../styles/navbar.css";
import { getCollection, type CollectionEntry } from "astro:content";

const packages = (await getCollection("packages")).sort((a: CollectionEntry<"packages">, b: CollectionEntry<"packages">) => a.data.title.localeCompare(b.data.title));
---
<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav-logo">
    <img src="/ctfx.jpg" alt="Logo" class="nav-logo-img" />
    <span>Laplahce</span>
  </a>
  <a href="/">Home</a>
  <div class="nav-dropdown">
    <button class="nav-dropdown-btn" tabindex="0">Products <span class="nav-caret">▼</span></button>
    <div class="nav-dropdown-content">
      {packages.map(pkg: CollectionEntry<"packages"> => (
        <a href={`/docs/${pkg.slug}`}>{pkg.data.title}</a>
      ))}
    </div>
  </div>
  <a href="#portfolio">Portfolio</a>
  <a href="#support">Support</a>
</nav>
---
import "../styles/navbar.css";
import { packagePages, getPackageLink } from "../lib/packages";
import type { NavbarLogo, NavbarDropdown, NavItem } from "../lib/types";

const logo: NavbarLogo = {
  src: '/ctfx.jpg',
  alt: 'Logo',
  label: 'Laplahce',
};

const productDropdown: NavbarDropdown = {
  label: 'Products',
  items: packagePages.map(pkg => {
    const link = getPackageLink(pkg);
    return { label: link.title, href: link.href };
  }),
};
---
<nav class="nav" aria-label="Main navigation">
  <a href="/" class="nav-logo">
    <img src={logo.src} alt={logo.alt} class="nav-logo-img" />
    <span>{logo.label}</span>
  </a>

  <div class="nav-menu">
    <a href="/">Home</a>
    <div class="nav-dropdown">
      <button class="nav-dropdown-btn" tabindex="0" id="products-btn">{productDropdown.label} <span class="nav-caret">▼</span></button>
      <div class="nav-dropdown-content" id="products-menu">
        {productDropdown.items.map(item => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>
    <a href="#portfolio">Portfolio</a>
    <a href="#support">Support</a>
  </div>

  <button class="nav-hamburger" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<script>
  const hamburger = document.querySelector('.nav-hamburger');
  const menu = document.querySelector('.nav-menu');
  const productsBtn = document.getElementById('products-btn');
  const productsMenu = document.getElementById('products-menu');

  hamburger?.addEventListener('click', () => {
    menu?.classList.toggle('nav-menu-open');
    hamburger?.classList.toggle('nav-hamburger-open');
  });

  // Handle dropdown click for mobile
  productsBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    productsMenu?.classList.toggle('nav-dropdown-open');
    productsBtn?.classList.toggle('nav-dropdown-btn-open');
  });

  // Close menu when clicking outside
  document.addEventListener('click', (e) => {
    if (!hamburger?.contains(e.target) && !menu?.contains(e.target)) {
      menu?.classList.remove('nav-menu-open');
      hamburger?.classList.remove('nav-hamburger-open');
      productsMenu?.classList.remove('nav-dropdown-open');
      productsBtn?.classList.remove('nav-dropdown-btn-open');
    }
  });
</script>
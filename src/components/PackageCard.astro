---
// Define the allowed categories
type Category = 'Shaders' | 'Tools' | 'VFX' | '3D Models';

const { title, description, category, slug } = Astro.props as {
    title: string;
    description: string;
    category: Category;
    slug: string;
};

const getCategoryColor = (cat: Category) => {
    // TypeScript now knows 'cat' can ONLY be one of those 4 strings
    const colors: Record<Category, string> = {
        'Shaders': 'bg-purple-100 text-purple-700',
        'Tools': 'bg-emerald-100 text-emerald-700',
        'VFX': 'bg-amber-100 text-amber-700',
        '3D Models': 'bg-blue-100 text-blue-700'
    };
    return colors[cat] || 'bg-slate-100 text-slate-700';
}
---
<a href={`/docs/${slug}`} class="group flex flex-col bg-white p-6 border border-slate-200 rounded-2xl shadow-sm hover:shadow-md hover:border-indigo-200 transition-all duration-200 hover:-translate-y-1">
	<div class="flex items-center justify-between mb-4">
		<span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${getCategoryColor(category)}`}>
			{category}
		</span>
		<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-300 group-hover:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
		</svg>
	</div>
	
	<h3 class="text-xl font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">{title}</h3>
	<p class="text-slate-500 mt-2 text-sm leading-relaxed flex-grow">{description}</p>
</a>
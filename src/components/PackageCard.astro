---
const { title, description, category, slug } = Astro.props;
---
<a href={`/docs/${slug}`} class="group block p-6 border border-slate-100 rounded-xl hover:border-slate-300 transition-colors">
	<span class="text-[10px] uppercase tracking-widest text-slate-400 font-bold">{category}</span>
	<h3 class="text-xl font-medium mt-1 group-hover:text-blue-600 transition-colors">{title}</h3>
	<p class="text-slate-500 mt-2 text-sm line-clamp-2">{description}</p>
	<div class="mt-4 text-xs font-medium text-slate-400 uppercase tracking-tighter">View Documentation →</div>
</a>
---
const { title } = Astro.props;
---
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title} | Unity Architecture</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-50 text-slate-900 font-['Inter'] antialiased selection:bg-indigo-100 selection:text-indigo-900">
		
		{/* Sticky Glassmorphism Navbar */}
		<nav class="sticky top-0 z-50 w-full backdrop-blur-md bg-white/70 border-b border-slate-200/80">
			<div class="max-w-5xl mx-auto px-6 h-16 flex justify-between items-center">
				<a href="/" class="font-bold text-lg tracking-tight flex items-center gap-2">
					<div class="w-6 h-6 bg-indigo-600 rounded-md"></div>
					Unity_Archive
				</a>
				<div class="space-x-6 text-sm font-medium text-slate-500">
					<a href="/" class="hover:text-slate-900 transition-colors">Portfolio</a>
					<a href="https://github.com/yourusername" class="hover:text-slate-900 transition-colors">GitHub</a>
				</div>
			</div>
		</nav>

		<main class="max-w-5xl mx-auto px-6 py-12">
			<slot />
		</main>

		<footer class="max-w-5xl mx-auto px-6 py-8 mt-12 border-t border-slate-200 text-center text-sm text-slate-400">
			© {new Date().getFullYear()} Your Name. Built with Astro & Cloudflare.
		</footer>
	</body>
</html>
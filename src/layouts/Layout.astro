---
import "../styles/base.css";
import "../styles/layout.css";
import "../styles/responsive.css";
import Navbar from "../components/Navbar.astro";
import DocsSidebar from "../components/DocsSidebar.astro";

const { title = "Laplahce", headings } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body>
    <div class="noise"></div>

    <Navbar />

    <div class="wiki-shell">
      <aside class="wiki-sidebar wiki-sidebar-left">
        <DocsSidebar headings={headings} />
      </aside>
      <main>
        <slot />
      </main>
      <aside class="wiki-sidebar wiki-sidebar-right">
        <!-- Right sidebar: add widgets, ads, or extra info here -->
      </aside>
    </div>
  </body>
</html>
---
const { title } = Astro.props;
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title} | Unity Portfolio</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
	</head>
	<body class="bg-white text-slate-900 font-['Inter'] leading-relaxed">
		<nav class="border-b border-slate-100 py-4 mb-12">
			<div class="max-w-5xl mx-auto px-6 flex justify-between items-center">
				<a href="/" class="font-semibold text-lg tracking-tight">Unity_Archive</a>
				<div class="space-x-8 text-sm text-slate-500">
					<a href="/" class="hover:text-black">Portfolio</a>
					<a href="https://github.com/yourusername" class="hover:text-black">GitHub</a>
				</div>
			</div>
		</nav>
		<main class="max-w-5xl mx-auto px-6">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	img { max-width: 100%; height: auto; border-radius: 8px; }
	pre { padding: 1rem; border-radius: 8px; background: #f8fafc !important; border: 1px solid #e2e8f0; }
</style>
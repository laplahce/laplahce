---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Define the interface for the props to kill the 'any' type
interface Props {
  pkg: CollectionEntry<'packages'>;
}

export async function getStaticPaths() {
  const packages: CollectionEntry<'packages'>[] = await getCollection('packages');
  
  return packages.map((pkg: CollectionEntry<'packages'>) => ({
    params: { id: pkg.id }, 
    props: { pkg },
  }));
}

// 2. Extract props with explicit typing
const { pkg } = Astro.props as Props;

// 3. Render Markdown content
const { Content } = await render(pkg);
---

<Layout title={pkg.data.title}>
  <article class="prose lg:prose-xl mx-auto py-12">
    <header class="mb-8">
        <p class="text-indigo-600 font-semibold uppercase">{pkg.data.category}</p>
        <h1 class="text-5xl font-extrabold">{pkg.data.title}</h1>
    </header>
    
    <div class="markdown-body">
        <Content />
    </div>
  </article>
</Layout>
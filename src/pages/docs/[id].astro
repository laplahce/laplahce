---
import {
  getCollection,
  render,
  type CollectionEntry,
} from "astro:content";

import DocsLayout from "../../layouts/DocsLayout.astro";

interface Props {
  pkg: CollectionEntry<"packages">;
}

export async function getStaticPaths() {
  const packages = await getCollection("packages");

  return packages.map((pkg: CollectionEntry<"packages">) => ({
    params: { id: pkg.id.toLowerCase() },
    props: { pkg },
  }));
}

const { pkg } = Astro.props as Props;

const { Content } = await render(pkg);
---

<DocsLayout title={pkg.data.title}>
  <article class="docs-content">
    <header class="docs-header">
      <h1>{pkg.data.title}</h1>

      {
        pkg.data.description && (
          <p>{pkg.data.description}</p>
        )
      }
    </header>

    <Content />
  </article>
</DocsLayout>
---
import {
  getCollection,
  render,
  type CollectionEntry,
} from "astro:content";

import Layout from "../../layouts/Layout.astro";

interface Props {
  pkg: CollectionEntry<"packages">;
}

export async function getStaticPaths() {
  const packages = await getCollection("packages");

  return packages.map((pkg: CollectionEntry<"packages">) => ({
    params: { id: pkg.slug ?? pkg.id.toLowerCase() },
    props: { pkg },
  }));
}

const { pkg } = Astro.props as Props;

const { Content, headings } = await render(pkg);
---

<Layout title={pkg.data.title} headings={headings}>
  <article class="docs-content">
    <header class="docs-header">
      <h1>{pkg.data.title}</h1>
      {pkg.data.description && (<p>{pkg.data.description}</p>)}
    </header>
    <Content />
  </article>
</Layout>
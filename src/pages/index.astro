---
import Layout from "../layouts/Layout.astro";
import ProjectCarousel from "../components/ProjectCarousel.astro";
import MarkdownBlock from "../components/MarkdownBlock.astro";
import "../styles/hero.css";
import "../styles/project-card.css";
import { packagePages, getPackageLink } from "../lib/packages";
import { getHomePage, splitHomePageByCards } from "../lib/pages";
import type { Package, CardProps } from "../lib/types";

const packages: Package[] = packagePages;
const homePage = getHomePage();
const { heroLabel, heroTitle } = homePage.frontmatter;

const cards: CardProps[] = packages.map(pkg => {
  const link = getPackageLink(pkg);
  return {
    title: pkg.title,
    description: pkg.description,
    image: pkg.cardImage,
    href: link.href,
  };
});

const { before: markdownBefore, after: markdownAfter } = splitHomePageByCards(homePage.raw);
---
<Layout title="Laplahce">
  <section id="welcome" class="hero">
    <p class="hero-label">{heroLabel}</p>
    <h1>
      {heroTitle}
    </h1>
  </section>

  {markdownBefore && (
    <section class="markdown-content">
      <MarkdownBlock markdown={markdownBefore} />
    </section>
  )}

  <section id="featured-projects" class="project-grid">
    <ProjectCarousel cards={cards} />
  </section>

  {markdownAfter && (
    <section class="markdown-content">
      <MarkdownBlock markdown={markdownAfter} />
    </section>
  )}
</Layout>